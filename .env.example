OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_HOST=http://127.0.0.1:11434

# Optional: Google Cloud Speech-to-Text API key for online Mandarin STT.
# Copy this file to .env and set the real key there. Do not commit .env.
GOOGLE_CLOUD_SPEECH_API_KEY=your_google_cloud_speech_api_key
GOOGLE_CLOUD_SPEECH_TIMEOUT=18

# Optional: offline Vosk fallback on Raspberry Pi.
# VOSK_MODEL_PATH=/home/pi/models/vosk-model-small-cn
